# =============================================
# MEDLEY-BENCH .gitignore
# =============================================

# --- Credentials & secrets ---
kaggle.json
.env
.env.*

# --- Claude Code local config ---
.claude/settings.local.json
.claude/projects/
.claude/plans/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/

# --- Databases ---
*.db
*.sqlite
*.sqlite3

# --- Results (large, available via Kaggle / GitHub Releases) ---
results/

# --- Database files generated by admin pipeline ---
data/*.db
data/database.db

# --- Working / scratch ---
workspace/

# --- Human validation user data ---
human_validation/ratings.db

# --- macOS ---
.DS_Store

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- LaTeX build artifacts ---
latex/*.aux
latex/*.log
latex/*.out
latex/*.bbl
latex/*.blg
latex/*.fls
latex/*.fdb_latexmk
latex/*.synctex.gz

# --- Scripts with hardcoded paths ---
run_local_queue.sh
